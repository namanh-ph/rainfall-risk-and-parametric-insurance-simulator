# ─────────────────────────────────────────────────────────────────────
# Simulator — environment variable template
# Copy this file to .env and adjust as needed for local development.
# All variables use UPPER_SNAKE_CASE.
# ─────────────────────────────────────────────────────────────────────

# ── Project ──────────────────────────────────────────────────────────
PROJECT_NAME=Simulator
ENVIRONMENT=local

# ── Postgres / PostGIS ───────────────────────────────────────────────
POSTGRES_DB=simulator
POSTGRES_USER=simulator
POSTGRES_PASSWORD=simulator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy/psycopg DSN consumed by the backend
DATABASE_URL=postgresql+psycopg://simulator:simulator@postgres:5432/simulator

# ── Backend (FastAPI) ────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
APP_ENV=development
LOG_LEVEL=INFO

# ── Frontend (Vite) ──────────────────────────────────────────────────
FRONTEND_PORT=5173
# Canonical /api/v1 prefix consumed by the React app.
FRONTEND_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── MLflow ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_PORT=5000

# ── Data ingestion paths (used by the ingestion CLI) ─────────────────
ASSET_CSV_PATH=../data/assets.csv
RAINFALL_STATION_CSV_PATH=../data/rainfall_stations.csv
RAINFALL_OBSERVATION_CSV_PATH=../data/rainfall_observations.csv
BOUNDARY_FILE_PATH=../data/vic_lga_boundaries.geojson

# ── Asset-to-station matching ────────────────────────────────────────
# Optional: cap the matching distance (kilometres). Leave blank to match
# every asset to its nearest available station regardless of distance.
MATCH_STATIONS_MAX_DISTANCE_KM=
